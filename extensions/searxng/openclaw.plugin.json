{
  "id": "searxng",
  "providerAuthEnvVars": {
    "searxng": ["SEARXNG_URL"]
  },
  "uiHints": {
    "webSearch.baseUrl": {
      "label": "SearXNG URL",
      "help": "URL of your self-hosted SearXNG instance (fallback: SEARXNG_URL env var). No API key required.",
      "placeholder": "http://searxng:8080"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webSearch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "baseUrl": {
            "type": "string"
          }
        }
      }
    }
  }
}
